{
  "name": "mathboard",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter mathboard-backend --filter mathboard-frontend dev",
    "dev:backend": "pnpm --filter mathboard-backend dev",
    "dev:frontend": "pnpm --filter mathboard-frontend dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  }
}
